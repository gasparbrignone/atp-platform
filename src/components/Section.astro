---
/**
 * Groups a block of page content and applies consistent vertical rhythm.
 * Never nest Sections — compose multiple Sections at the page level instead.
 */
import type { HTMLAttributes } from 'astro/types';

export type SectionSpacing = 'sm' | 'md' | 'lg';
export type SectionBackground = 'background' | 'surface' | 'surface-alt';

interface Props extends HTMLAttributes<'section'> {
  as?: keyof HTMLElementTagNameMap;
  spacing?: SectionSpacing;
  background?: SectionBackground;
  /**
   * Fades + rises the whole section in as it scrolls into view (see
   * global.css / src/lib/scrollReveal.ts). Defaults on since most Sections
   * sit below the fold; Hero opts out explicitly — it's already in the
   * initial viewport, so a scroll-triggered reveal would just delay it.
   */
  reveal?: boolean;
}

const {
  as: Tag = 'section',
  spacing = 'md',
  background = 'background',
  reveal = true,
  class: className,
  ...rest
}: Props = Astro.props;

const spacingClasses: Record<SectionSpacing, string> = {
  sm: 'py-12',
  md: 'py-16',
  lg: 'py-24',
};

const backgroundClasses: Record<SectionBackground, string> = {
  background: 'bg-background',
  surface: 'bg-surface',
  'surface-alt': 'bg-surface-alt',
};
---

<Tag
  class:list={[spacingClasses[spacing], backgroundClasses[background], className]}
  data-reveal={reveal ? '' : undefined}
  {...rest}
>
  <slot />
</Tag>
