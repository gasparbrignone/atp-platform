---
/**
 * Groups a block of page content and applies consistent vertical rhythm.
 * Never nest Sections — compose multiple Sections at the page level instead.
 */
import type { HTMLAttributes } from 'astro/types';

export type SectionSpacing = 'sm' | 'md' | 'lg';
export type SectionBackground = 'background' | 'surface' | 'surface-alt';

interface Props extends HTMLAttributes<'section'> {
  as?: keyof HTMLElementTagNameMap;
  spacing?: SectionSpacing;
  background?: SectionBackground;
}

const {
  as: Tag = 'section',
  spacing = 'md',
  background = 'background',
  class: className,
  ...rest
}: Props = Astro.props;

const spacingClasses: Record<SectionSpacing, string> = {
  sm: 'py-12',
  md: 'py-16',
  lg: 'py-24',
};

const backgroundClasses: Record<SectionBackground, string> = {
  background: 'bg-background',
  surface: 'bg-surface',
  'surface-alt': 'bg-surface-alt',
};
---

<Tag class:list={[spacingClasses[spacing], backgroundClasses[background], className]} {...rest}>
  <slot />
</Tag>
