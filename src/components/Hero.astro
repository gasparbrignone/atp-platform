---
/**
 * Fully generic, prop-driven hero. Carries no ATP-specific copy — every
 * page composing a Hero passes its own title/description/actions/image.
 * Never occupies excessive height on mobile: it sizes to its content
 * (no min-h-screen), only Section's padding scale controls its spacing.
 */
import type { AstroComponentFactory } from 'astro/runtime/server/index.js';
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import Section from './Section.astro';
import Container from './Container.astro';
import Button from './Button.astro';
import type { SectionBackground } from './Section.astro';

export type HeroAlignment = 'left' | 'center';

interface HeroAction {
  label: string;
  href: string;
  /** Optional icon component rendered before the label (e.g. a brand mark). */
  icon?: AstroComponentFactory;
}

interface HeroImage {
  src: string;
  alt: string;
  width: number;
  height: number;
}

interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  primaryAction?: HeroAction;
  secondaryAction?: HeroAction;
  image?: HeroImage;
  /**
   * Full-bleed photo behind the whole Hero, with a dark overlay for text
   * contrast — distinct from `image`, which sits beside the text instead of
   * behind it. Always a local, build-time-optimized asset (imported via
   * `import photo from '@/assets/...'`), never a raw path — that's what lets
   * `<Image>` generate a right-sized, modern-format file instead of shipping
   * the original multi-MB photo. Rendered with `alt=""` since it's
   * decorative: the heading and description already carry the Hero's
   * meaning.
   */
  backgroundImage?: ImageMetadata;
  alignment?: HeroAlignment;
  backgroundVariant?: SectionBackground;
  /** Heading tag for `title`. Defaults to h1 — override to h2 if this Hero isn't the page's main heading. */
  as?: 'h1' | 'h2';
  /**
   * Visually hides the rendered `title` text (kept in the DOM, `sr-only`,
   * for a11y/SEO) — for callers filling the `logo` slot with a wordmark
   * that should read as the heading instead of duplicating it as text.
   */
  hideTitleVisually?: boolean;
}

const {
  title,
  subtitle,
  description,
  primaryAction,
  secondaryAction,
  image,
  backgroundImage,
  alignment = 'center',
  backgroundVariant = 'background',
  as: Heading = 'h1',
  hideTitleVisually = false,
}: Props = Astro.props;

const isCentered = alignment === 'center';
---

<Section
  spacing="lg"
  background={backgroundVariant}
  reveal={false}
  class:list={backgroundImage && 'relative isolate overflow-hidden'}
>
  {
    backgroundImage && (
      <>
        <Image
          src={backgroundImage}
          alt=""
          aria-hidden="true"
          loading="eager"
          widths={[640, 1024, 1536, 1920]}
          sizes="100vw"
          quality="high"
          class="absolute inset-0 -z-20 size-full object-cover"
        />
        {
          /*
           * A single flat wash reads flat/dated and either crushes the
           * photo everywhere or leaves the top too bright for white text —
           * a top-to-bottom gradient keeps the photo's own brightness
           * doing the work instead of fighting it. `--gray-900` (never pure
           * black, per tokens.css) hardcoded as rgb here since Tailwind's
           * gradient utilities can't consume a hex custom property's
           * channels directly.
           */
        }
        <div class="hero-gradient absolute inset-0 -z-10" />
      </>
    )
  }
  <Container
    class:list={[
      'flex flex-col items-center gap-10 text-center',
      !isCentered && 'lg:flex-row lg:text-left',
    ]}
  >
    <div
      class:list={['flex max-w-2xl flex-col items-center gap-4', !isCentered && 'lg:items-start']}
    >
      <div data-enter>
        <slot name="logo" />
        <Heading
          class:list={[
            'text-h1 font-extrabold',
            hideTitleVisually && 'sr-only',
            backgroundImage
              ? 'text-white'
              : 'from-primary-fill to-primary-strong bg-gradient-to-t bg-clip-text text-transparent',
          ]}
        >
          {title}
        </Heading>
      </div>
      {
        subtitle && (
          <p
            data-enter
            style="--enter-delay: 80ms"
            class:list={[
              'text-h4 font-semibold',
              backgroundImage ? 'text-white' : 'text-text-secondary',
            ]}
          >
            {subtitle}
          </p>
        )
      }
      {
        description && (
          <p
            data-enter
            style="--enter-delay: 80ms"
            class:list={['text-body-lg', backgroundImage ? 'text-white/90' : 'text-text-secondary']}
          >
            {description}
          </p>
        )
      }
      {
        (primaryAction || secondaryAction) && (
          <div data-enter style="--enter-delay: 160ms" class="mt-2 flex flex-col gap-3 sm:flex-row">
            {primaryAction && (
              <Button href={primaryAction.href} size="lg">
                {primaryAction.icon && <primaryAction.icon slot="icon-start" class="size-4" />}
                {primaryAction.label}
              </Button>
            )}
            {secondaryAction && (
              <Button href={secondaryAction.href} size="lg" variant="outline">
                {secondaryAction.label}
              </Button>
            )}
          </div>
        )
      }
      <slot name="extra" />
    </div>

    {
      image && (
        <div class="w-full max-w-md shrink-0 lg:max-w-lg">
          {/* Plain <img>, not astro:assets' <Image>: src/width/height come from
              generic props, not a known local asset or allow-listed remote
              domain yet. Revisit once Fase 3 (Home) sources real images. */}
          <img
            src={image.src}
            alt={image.alt}
            width={image.width}
            height={image.height}
            loading="eager"
            decoding="async"
            class="h-auto w-full rounded-lg"
          />
        </div>
      )
    }
  </Container>
</Section>

<style>
  /*
   * Plain CSS, not Tailwind's gradient utilities: a 4-stop gradient with
   * exact per-stop opacity is clearer written out than chaining several
   * "from/via/to" utilities, and Tailwind can't read an alpha value off a
   * hex custom property anyway. rgb(28, 25, 38) is --gray-900 (see
   * tokens.css) — kept in sync by hand since there are only two call
   * sites (here and nowhere else this value is needed as raw channels).
   */
  .hero-gradient {
    background: linear-gradient(
      180deg,
      rgba(28, 25, 38, 0.88) 0%,
      rgba(28, 25, 38, 0.65) 42%,
      rgba(28, 25, 38, 0.8) 68%,
      rgba(28, 25, 38, 0.95) 100%
    );
  }
</style>
