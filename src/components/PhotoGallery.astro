---
/**
 * Bento-style photo mosaic: first photo runs large and featured, the rest
 * fill in around it. Used on pages that want a dynamic, photo-led section
 * (Sumate, Actividades) instead of a plain uniform grid.
 */
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface GalleryPhoto {
  image: ImageMetadata;
  alt: string;
}

interface Props {
  photos: GalleryPhoto[];
}

const { photos }: Props = Astro.props;
---

<div class="grid grid-cols-2 gap-4 md:grid-cols-4 md:auto-rows-[200px]">
  {
    photos.map(({ image, alt }, index) => (
      <div
        class:list={[
          'group ease-standard relative overflow-hidden rounded-md transition-shadow duration-200',
          'shadow-[0_1px_2px_rgba(28,25,38,0.06),0_1px_1px_rgba(28,25,38,0.04)] hover:shadow-[0_12px_24px_rgba(28,25,38,0.12),0_2px_8px_rgba(28,25,38,0.06)]',
          index === 0
            ? 'col-span-2 aspect-video md:aspect-auto md:row-span-2'
            : 'aspect-square md:aspect-auto',
        ]}
      >
        <Image
          src={image}
          alt={alt}
          loading={index === 0 ? 'eager' : 'lazy'}
          widths={[320, 480, 640, 960]}
          sizes={index === 0 ? '(min-width: 768px) 50vw, 100vw' : '(min-width: 768px) 25vw, 50vw'}
          quality="high"
          class="ease-standard size-full object-cover transition-transform duration-300 group-hover:scale-105"
        />
      </div>
    ))
  }
</div>
