---
/**
 * Main site navigation. Sticky, solid background, constant height — only
 * the shadow responds to scroll (see DESIGN.md → Navbar). The mobile
 * drawer itself lives in MobileMenu.astro; this component only renders the
 * trigger button that opens it.
 *
 * Fully opaque background, no translucency and no `backdrop-blur` (both
 * used to be true): a `position: sticky` element letting content scroll
 * through it even partially — via transparency, blur, or both — reads as
 * a visible glitch once the content behind it is the home's large,
 * busy Hero photo (seen in production: card/nav content visibly bleeding
 * through the bar during fast scroll). Solid is the only way to guarantee
 * it never happens, regardless of the browser's compositing behavior.
 *
 * All nav links now point to real pages (see docs/ROADMAP.md for the
 * remaining phases still ahead, e.g. institutional pages).
 */
import Menu from '@lucide/astro/icons/menu';
import ChevronDown from '@lucide/astro/icons/chevron-down';
import Container from './Container.astro';
import Button from './Button.astro';
import MobileMenu from './MobileMenu.astro';
import AtpMark from './icons/AtpMark.astro';
import Logo from './icons/Logo.astro';
import { getCollection } from 'astro:content';
import { careerLabels, type CareerSlug } from '@/lib/labels';

const careers = await getCollection('careers');
const careerChildren = (Object.keys(careerLabels) as CareerSlug[])
  .filter((slug) => careers.some((career) => career.id === slug))
  .map((slug) => ({ label: careerLabels[slug], href: `/carreras/${slug}` }));

const publishedTools = await getCollection('tools', ({ data }) => data.published);
const toolChildren = publishedTools.map((tool) => ({
  label: tool.data.name,
  href: `/herramientas/${tool.id}`,
}));

const navLinks = [
  { label: 'Inicio', href: '/' },
  { label: 'Biblioteca', href: '/biblioteca' },
  { label: 'Actividades', href: '/actividades' },
  { label: 'Mapa', href: '/mapa' },
  { label: 'Carreras', href: '/carreras', children: careerChildren },
  { label: '+info', href: '/herramientas', children: toolChildren },
];
---

<header
  data-navbar
  class="z-sticky bg-surface ease-standard data-scrolled:border-border sticky top-0 w-full border-b border-transparent transition-[box-shadow,border-color] duration-200 data-scrolled:shadow-sm"
>
  <Container as="nav" aria-label="Principal" class="flex h-16 items-center justify-between">
    <a href="/" class="text-text flex items-center">
      <Logo class="h-8 w-auto" />
      <span class="sr-only">ATP</span>
    </a>

    <ul class="hidden items-center gap-8 md:flex">
      {
        navLinks.map((link) =>
          link.children && link.children.length > 0 ? (
            <li class="relative">
              <div class="flex items-center">
                <a
                  href={link.href}
                  class="text-body text-text-secondary ease-standard hover:text-text after:ease-standard relative font-semibold transition-colors duration-150 after:absolute after:-bottom-1 after:left-0 after:h-0.5 after:w-full after:origin-left after:scale-x-0 after:bg-current after:transition-transform after:duration-200 after:content-[''] hover:after:scale-x-100"
                >
                  {link.label}
                </a>
                <button
                  type="button"
                  data-desktop-submenu-toggle
                  aria-haspopup="true"
                  aria-expanded="false"
                  aria-label={`Mostrar ${link.label}`}
                  class="text-text-secondary ease-standard hover:text-text -mr-1 inline-flex size-6 items-center justify-center transition-colors duration-150"
                >
                  <ChevronDown
                    data-desktop-submenu-chevron
                    class="ease-standard size-4 transition-transform duration-200"
                    aria-hidden="true"
                  />
                </button>
              </div>
              <ul
                data-desktop-submenu
                class="bg-surface border-border ease-standard z-dropdown invisible absolute top-full left-0 mt-2 flex min-w-48 -translate-y-1 flex-col gap-0.5 rounded-md border p-1.5 opacity-0 shadow-lg transition-[opacity,transform,visibility] duration-150"
              >
                {link.children.map((child) => (
                  <li>
                    <a
                      href={child.href}
                      class="text-body-sm text-text-secondary ease-standard hover:bg-surface-alt hover:text-text block rounded-sm px-3 py-2 font-semibold transition-colors duration-150"
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            </li>
          ) : (
            <li>
              <a
                href={link.href}
                class="text-body text-text-secondary ease-standard hover:text-text after:ease-standard relative font-semibold transition-colors duration-150 after:absolute after:-bottom-1 after:left-0 after:h-0.5 after:w-full after:origin-left after:scale-x-0 after:bg-current after:transition-transform after:duration-200 after:content-[''] hover:after:scale-x-100"
              >
                {link.label}
              </a>
            </li>
          ),
        )
      }
    </ul>

    <div class="flex items-center gap-2">
      <Button href="/sumate" size="sm" class="hidden md:inline-flex">
        <AtpMark slot="icon-start" class="size-4" />
        Sumate a ATP
      </Button>

      <button
        type="button"
        id="mobile-menu-trigger"
        aria-haspopup="dialog"
        aria-controls="mobile-menu"
        aria-expanded="false"
        class="text-text-secondary ease-standard hover:bg-surface-alt inline-flex size-10 items-center justify-center rounded-full transition-colors duration-150 md:hidden"
      >
        <span class="sr-only">Abrir menú</span>
        <Menu class="size-5" aria-hidden="true" />
      </button>
    </div>
  </Container>
</header>

<MobileMenu links={navLinks} />

<script>
  const header = document.querySelector<HTMLElement>('[data-navbar]');

  function updateScrolled() {
    header?.toggleAttribute('data-scrolled', window.scrollY > 8);
  }

  updateScrolled();
  window.addEventListener('scroll', updateScrolled, { passive: true });

  // Desktop Carreras/+info dropdowns — closed by default, one open at a
  // time, dismissed on outside click or Escape (unlike the mobile
  // accordion in MobileMenu.astro, which stays open within the drawer).
  const toggles = Array.from(
    document.querySelectorAll<HTMLButtonElement>('[data-desktop-submenu-toggle]'),
  );

  function closeSubmenu(toggle: HTMLButtonElement) {
    const submenu = toggle.parentElement?.nextElementSibling;
    const chevron = toggle.querySelector<HTMLElement>('[data-desktop-submenu-chevron]');
    if (!(submenu instanceof HTMLElement)) return;
    toggle.setAttribute('aria-expanded', 'false');
    submenu.classList.add('invisible', 'opacity-0', '-translate-y-1');
    chevron?.classList.remove('rotate-180');
  }

  function openSubmenu(toggle: HTMLButtonElement) {
    const submenu = toggle.parentElement?.nextElementSibling;
    const chevron = toggle.querySelector<HTMLElement>('[data-desktop-submenu-chevron]');
    if (!(submenu instanceof HTMLElement)) return;
    toggle.setAttribute('aria-expanded', 'true');
    submenu.classList.remove('invisible', 'opacity-0', '-translate-y-1');
    chevron?.classList.add('rotate-180');
  }

  toggles.forEach((toggle) => {
    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      toggles.forEach((other) => other !== toggle && closeSubmenu(other));
      if (isOpen) {
        closeSubmenu(toggle);
      } else {
        openSubmenu(toggle);
      }
    });
  });

  document.addEventListener('click', (event) => {
    const target = event.target;
    const clickedInsideAny =
      target instanceof Node && toggles.some((toggle) => toggle.closest('li')?.contains(target));
    if (!clickedInsideAny) toggles.forEach(closeSubmenu);
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') toggles.forEach(closeSubmenu);
  });
</script>
