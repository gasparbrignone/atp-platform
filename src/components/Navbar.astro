---
/**
 * Main site navigation. Sticky, glass background, constant height —
 * only the background/shadow respond to scroll (see DESIGN.md → Navbar).
 * The mobile drawer itself lives in MobileMenu.astro; this component only
 * renders the trigger button that opens it.
 *
 * Nav links are placeholder content (no real pages exist yet outside "/").
 */
import Menu from '@lucide/astro/icons/menu';
import Sun from '@lucide/astro/icons/sun';
import Moon from '@lucide/astro/icons/moon';
import Container from './Container.astro';
import Button from './Button.astro';
import MobileMenu from './MobileMenu.astro';

const navLinks = [
  { label: 'Inicio', href: '/' },
  { label: 'Biblioteca', href: '#' },
  { label: 'Actividades', href: '#' },
  { label: 'Noticias', href: '#' },
  { label: 'Carreras', href: '#' },
];
---

<header
  data-navbar
  class="z-sticky bg-surface/70 ease-standard data-scrolled:border-border data-scrolled:bg-surface/90 sticky top-0 w-full border-b border-transparent backdrop-blur-md transition-[background-color,box-shadow,border-color] duration-200 data-scrolled:shadow-sm"
>
  <Container as="nav" aria-label="Principal" class="flex h-16 items-center justify-between">
    <a href="/" class="text-h4 text-text flex items-center gap-2 font-extrabold">
      <img src="/branding/logo.svg" alt="" class="h-8 w-auto" />
      ATP
    </a>

    <ul class="hidden items-center gap-8 md:flex">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-body text-text-secondary ease-standard hover:text-text font-semibold transition-colors duration-150"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-2">
      <button
        type="button"
        id="theme-toggle"
        aria-pressed="false"
        class="text-text-secondary ease-standard hover:bg-surface-alt inline-flex size-10 items-center justify-center rounded-full transition-colors duration-150"
      >
        <span class="sr-only">Cambiar tema</span>
        <Sun id="theme-toggle-sun" class="size-5" aria-hidden="true" />
        <Moon id="theme-toggle-moon" class="hidden size-5" aria-hidden="true" />
      </button>

      <Button href="#" size="sm" class="hidden md:inline-flex">Sumate a ATP</Button>

      <button
        type="button"
        id="mobile-menu-trigger"
        aria-haspopup="dialog"
        aria-controls="mobile-menu"
        aria-expanded="false"
        class="text-text-secondary ease-standard hover:bg-surface-alt inline-flex size-10 items-center justify-center rounded-full transition-colors duration-150 md:hidden"
      >
        <span class="sr-only">Abrir menú</span>
        <Menu class="size-5" aria-hidden="true" />
      </button>
    </div>
  </Container>
</header>

<MobileMenu links={navLinks} />

<script>
  const STORAGE_KEY = 'atp-theme';
  const toggle = document.querySelector<HTMLElement>('#theme-toggle');
  const sunIcon = document.querySelector<HTMLElement>('#theme-toggle-sun');
  const moonIcon = document.querySelector<HTMLElement>('#theme-toggle-moon');

  function getEffectiveTheme(): 'light' | 'dark' {
    const stored = localStorage.getItem(STORAGE_KEY);
    if (stored === 'light' || stored === 'dark') return stored;
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  }

  function applyIcon(theme: 'light' | 'dark') {
    sunIcon?.classList.toggle('hidden', theme === 'dark');
    moonIcon?.classList.toggle('hidden', theme !== 'dark');
    toggle?.setAttribute('aria-pressed', String(theme === 'dark'));
  }

  applyIcon(getEffectiveTheme());

  toggle?.addEventListener('click', () => {
    const next = getEffectiveTheme() === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem(STORAGE_KEY, next);
    applyIcon(next);
  });
</script>

<script>
  const header = document.querySelector<HTMLElement>('[data-navbar]');

  function updateScrolled() {
    header?.toggleAttribute('data-scrolled', window.scrollY > 8);
  }

  updateScrolled();
  window.addEventListener('scroll', updateScrolled, { passive: true });
</script>
