---
/**
 * Base card. Every specialized card (ActivityCard, BookCard, ToolCard...)
 * must extend this component instead of reimplementing its own surface —
 * never build a one-off card style outside this system.
 *
 * Sections are named slots so the caller controls heading levels and
 * markup (needed to keep page heading hierarchy correct), while `image`,
 * `badge` and `actions` stay optional as required by UI_COMPONENTS.md.
 */
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'div'> {
  as?: keyof HTMLElementTagNameMap;
}

const { as: Tag = 'div', class: className, ...rest }: Props = Astro.props;
---

<Tag
  class:list={[
    /*
     * Soft layered depth (inspired by Cult UI's MinimalCard shadow recipe,
     * ported to plain Tailwind + our own warm near-black instead of their
     * hardcoded rgba(0,0,0,...)) plus a gentle lift on hover — the site's
     * "premium, calm" cards should feel closer to an Apple product card
     * than a flat bordered box. Kept to a translate + shadow swap only:
     * no scale, no color change, so it stays subtle per CLAUDE.md.
     *
     * `active:` mirrors this for touch: phones never trigger `:hover`, so
     * without it every card lift/shadow was invisible on mobile. `:active`
     * bubbles up from whatever's tapped inside the card (a Button, a link),
     * so this fires even though Card itself is a plain non-interactive div.
     */
    'border-border bg-surface ease-standard flex flex-col overflow-hidden rounded-md border transition-[transform,box-shadow] duration-200',
    'shadow-[0_1px_2px_rgba(28,25,38,0.06),0_1px_1px_rgba(28,25,38,0.04)]',
    'hover:-translate-y-1 hover:shadow-[0_12px_24px_rgba(28,25,38,0.12),0_2px_8px_rgba(28,25,38,0.06)]',
    'active:scale-[0.98] active:duration-100',
    className,
  ]}
  {...rest}
>
  <slot name="image" />
  <div class="flex flex-1 flex-col gap-3 p-6">
    <slot name="badge" />
    <slot name="title" />
    <div class="text-body text-text-secondary flex-1">
      <slot />
    </div>
    <slot name="actions" />
  </div>
</Tag>
