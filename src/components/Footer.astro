---
/**
 * Site-wide footer. Quick links are placeholder content — no real pages
 * exist yet outside "/" (see docs/ROADMAP.md, upcoming phases).
 *
 * Section labels are plain text, not headings: Footer is reused on every
 * page regardless of that page's own heading structure, so it relies on
 * the `nav[aria-label]` landmarks for accessible structure instead of
 * contributing to the document's heading outline (same reasoning as
 * Card's named slots — see Card.astro).
 */
import Container from './Container.astro';
import SocialLinks from './SocialLinks.astro';

const quickLinks = [
  { label: 'Inicio', href: '/' },
  { label: 'Biblioteca', href: '/biblioteca' },
  { label: 'Actividades', href: '/actividades' },
  { label: 'Sumate a ATP', href: '#' },
];

const year = new Date().getFullYear();
---

<footer class="border-border bg-surface-alt border-t">
  <Container class="flex flex-col gap-10 py-16">
    <div class="flex flex-col gap-10 md:flex-row md:justify-between">
      <div class="flex max-w-sm flex-col gap-3">
        <a href="/" class="flex items-center">
          <img src="/branding/logo.svg" alt="ATP" class="h-8 w-auto" />
        </a>
        <p class="text-body-sm text-text-secondary">
          Agrupación estudiantil de Ciencias Médicas (UNR).
        </p>
      </div>

      <nav aria-label="Enlaces rápidos">
        <p class="text-overline text-text-secondary font-semibold uppercase">Enlaces rápidos</p>
        <ul class="mt-4 flex flex-col gap-2">
          {
            quickLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-body text-text-secondary ease-standard hover:text-text transition-colors duration-150"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div>
        <p class="text-overline text-text-secondary font-semibold uppercase">Seguinos</p>
        <div class="mt-4">
          <SocialLinks />
        </div>
      </div>
    </div>

    <div
      class="border-border text-caption text-text-secondary flex flex-col gap-2 border-t pt-6 md:flex-row md:items-center md:justify-between"
    >
      <p>&copy; {year} ATP. Todos los derechos reservados.</p>
      <p>Hecho por estudiantes, para estudiantes.</p>
    </div>
  </Container>
</footer>
