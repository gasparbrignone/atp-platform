---
/**
 * The single official component for every clickable action in the platform.
 * Renders as a <button> by default, or as an <a> when `href` is provided —
 * never build a separate "LinkButton".
 *
 * Icons are passed through the `icon-start` / `icon-end` slots so this
 * component stays icon-library-agnostic.
 */
import type { HTMLAttributes } from 'astro/types';
import { getSpinnerClasses } from '@/lib/spinnerClasses';

export type ButtonVariant = 'primary' | 'secondary' | 'outline' | 'ghost' | 'danger';
export type ButtonSize = 'sm' | 'md' | 'lg';
export type ButtonTarget = '_self' | '_blank' | '_parent' | '_top';

interface Props extends HTMLAttributes<'button'> {
  variant?: ButtonVariant;
  size?: ButtonSize;
  href?: string;
  /** Only applied when `href` is set. Ignored on the `<button>` render path. */
  target?: ButtonTarget;
  /** Only applied when `href` is set. Defaults to `noopener noreferrer` when `target="_blank"` and no `rel` is given. */
  rel?: string;
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  loading?: boolean;
  /**
   * Opt-in analytics event id (GoatCounter, see BaseLayout.astro). Leave
   * unset for ordinary navigation/UI buttons — only pass this for the
   * actions actually worth measuring (downloads, registrations, key CTAs),
   * per docs/STACK_DECISIONS.md ("no recopilar datos innecesarios").
   */
  trackId?: string;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  target,
  rel,
  type = 'button',
  disabled = false,
  loading = false,
  trackId,
  class: className,
  ...rest
}: Props = Astro.props;

const resolvedRel = target === '_blank' ? (rel ?? 'noopener noreferrer') : rel;

const isDisabled = disabled || loading;

const sizeClasses: Record<ButtonSize, string> = {
  sm: 'h-8 gap-2 px-3 text-body-sm',
  md: 'h-10 gap-2 px-4 text-body',
  lg: 'h-12 gap-3 px-6 text-body-lg',
};

/*
 * Outline/ghost are secondary actions ("Ver más", "Explorar"...), not CTAs
 * — they use `secondary-strong` (institutional blue) so the brand pink
 * stays reserved for `primary` (the actual call to action). `-strong`
 * variants exist because their base tokens are too light/dark to pass
 * WCAG AA as bare text/border against a page background in one theme or
 * the other (see tokens.css). Solid fills (primary/secondary/danger) pair
 * with their `-foreground` token instead, since a fill's contrast is
 * self-contained.
 *
 * `primary` uses `primary-fill` (not the bare `--color-primary` brand
 * pink) because white text on the brand pink is only 2.6:1 — fails WCAG
 * AA. `primary-fill` is a deliberately darker, fixed-across-themes pink
 * that clears 4.99:1 with white (see tokens.css).
 */
const variantClasses: Record<ButtonVariant, string> = {
  primary:
    'bg-primary-fill text-primary-fill-foreground hover:brightness-110 active:brightness-125',
  secondary: 'bg-secondary text-secondary-foreground hover:brightness-95 active:brightness-90',
  outline:
    'border border-secondary-strong bg-transparent text-secondary-strong hover:bg-secondary/10 active:bg-secondary/20',
  ghost: 'bg-transparent text-secondary-strong hover:bg-secondary/10 active:bg-secondary/20',
  danger: 'bg-error text-error-foreground hover:brightness-95 active:brightness-90',
};

const classes = [
  'inline-flex select-none items-center justify-center whitespace-nowrap rounded-sm font-semibold transition-[filter,background-color,opacity] duration-150 ease-standard',
  'disabled:pointer-events-none disabled:opacity-40 aria-disabled:pointer-events-none aria-disabled:opacity-40',
  sizeClasses[size],
  variantClasses[variant],
  className,
];

const Tag = href ? 'a' : 'button';
---

<Tag
  class:list={classes}
  href={href && !disabled ? href : undefined}
  target={href ? target : undefined}
  rel={href ? resolvedRel : undefined}
  type={href ? undefined : type}
  disabled={href ? undefined : isDisabled}
  aria-disabled={href && isDisabled ? true : undefined}
  aria-busy={loading ? 'true' : undefined}
  tabindex={href && isDisabled ? -1 : undefined}
  data-goatcounter-click={trackId}
  {...rest}
>
  {loading && <span class:list={['shrink-0', getSpinnerClasses('sm')]} aria-hidden="true" />}
  <slot name="icon-start" />
  <slot />
  <slot name="icon-end" />
</Tag>
