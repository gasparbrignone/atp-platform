---
/**
 * Self-moving "tetris" mosaic: tiles of mixed widths/heights sitting on a
 * shared baseline, endlessly sliding in from the left and off to the right.
 * Pure CSS (translateX keyframes on a doubled track) — no JS, and it stops
 * outright for prefers-reduced-motion instead of just slowing down, since
 * the motion itself isn't essential to the content.
 */
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface MarqueePhoto {
  image: ImageMetadata;
  alt: string;
}

interface Props {
  photos: MarqueePhoto[];
}

const { photos }: Props = Astro.props;

type TileSize = 'sm' | 'md' | 'lg' | 'xl';

const sizeCycle: TileSize[] = ['md', 'lg', 'sm', 'xl', 'md', 'sm', 'lg'];

const tileClasses: Record<TileSize, string> = {
  sm: 'h-28 w-36 sm:h-32 sm:w-44',
  md: 'h-36 w-44 sm:h-44 sm:w-56',
  lg: 'h-44 w-52 sm:h-52 sm:w-64',
  xl: 'h-52 w-60 sm:h-64 sm:w-80',
};

const tiles = photos.map((photo, index) => ({
  ...photo,
  size: sizeCycle[index % sizeCycle.length],
}));

// Doubled so the track can loop seamlessly: at the halfway point the second
// copy lines up exactly where the first one started.
const track = [...tiles, ...tiles];
---

<div class="marquee-viewport -mx-4 overflow-hidden sm:mx-0">
  <div class="marquee-track flex w-max items-end gap-4">
    {
      track.map(({ image, alt, size }, index) => (
        <div class:list={['shrink-0 overflow-hidden rounded-md', tileClasses[size]]}>
          <Image
            src={image}
            alt={alt}
            loading={index < tiles.length ? 'eager' : 'lazy'}
            aria-hidden={index >= tiles.length ? 'true' : undefined}
            widths={[320, 480, 640]}
            sizes="320px"
            quality="high"
            class="size-full object-cover"
          />
        </div>
      ))
    }
  </div>
</div>

<style>
  .marquee-track {
    animation: marquee-right 40s linear infinite;
  }

  .marquee-viewport:hover .marquee-track,
  .marquee-viewport:focus-within .marquee-track {
    animation-play-state: paused;
  }

  @keyframes marquee-right {
    from {
      transform: translateX(-50%);
    }
    to {
      transform: translateX(0%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
    }
  }
</style>
