---
/**
 * Self-moving Pinterest-style photo wall: a tight 3-row grid of portrait
 * tiles (no gaps to the background, just a small gutter between photos)
 * that endlessly slides in from the left and off to the right as one
 * block. Pure CSS (translateX keyframes on a doubled grid) — no JS, and it
 * stops outright for prefers-reduced-motion instead of just slowing down,
 * since the motion itself isn't essential to the content.
 */
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface MarqueePhoto {
  image: ImageMetadata;
  alt: string;
}

interface Props {
  photos: MarqueePhoto[];
}

const { photos }: Props = Astro.props;

const rows = 3;
// Padded to a multiple of `rows` so every column is fully filled — a
// partial last column would leave a blank hole in the grid.
const columns = Math.ceil(photos.length / rows);
const tiles = Array.from({ length: columns * rows }, (_, i) => photos[i % photos.length]);

// Doubled so the grid can loop seamlessly: at the halfway point the second
// copy lines up exactly where the first one started.
const track = [...tiles, ...tiles];
---

<div class="marquee-viewport overflow-hidden">
  <div
    class="marquee-track grid h-[600px] auto-cols-[140px] grid-flow-col grid-rows-3 gap-3 sm:h-[750px] sm:auto-cols-[170px] sm:gap-4 lg:h-[900px] lg:auto-cols-[200px]"
  >
    {
      track.map(({ image, alt }, index) => (
        <div class="overflow-hidden rounded-lg">
          <Image
            src={image}
            alt={alt}
            loading={index < tiles.length ? 'eager' : 'lazy'}
            aria-hidden={index >= tiles.length ? 'true' : undefined}
            widths={[240, 340, 400]}
            sizes="200px"
            quality="high"
            class="size-full object-cover"
          />
        </div>
      ))
    }
  </div>
</div>

<style>
  .marquee-track {
    animation: marquee-right 32s linear infinite;
  }

  .marquee-viewport:hover .marquee-track,
  .marquee-viewport:focus-within .marquee-track {
    animation-play-state: paused;
  }

  @keyframes marquee-right {
    from {
      transform: translateX(-50%);
    }
    to {
      transform: translateX(0%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
    }
  }
</style>
