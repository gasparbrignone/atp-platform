---
/**
 * Represents one active filter inside a FilterPanel. Owns no filter state —
 * clicking remove just dispatches a bubbling CustomEvent so whatever script
 * manages the actual filter state (per page, since criteria differ between
 * biblioteca/actividades/herramientas) can react to it.
 */
import X from '@lucide/astro/icons/x';
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'span'> {
  /** Identifies which filter this chip represents (e.g. "career:medicina"). */
  value: string;
  label: string;
}

const { value, label, class: className, ...rest }: Props = Astro.props;
---

<span
  data-filter-chip={value}
  class:list={[
    'bg-secondary/10 text-secondary-strong text-body-sm inline-flex items-center gap-1.5 rounded-full py-1 pr-1.5 pl-3 font-semibold',
    className,
  ]}
  {...rest}
>
  {label}
  <button
    type="button"
    data-filter-chip-remove
    aria-label={`Quitar filtro ${label}`}
    class="ease-standard hover:bg-secondary/20 inline-flex size-5 items-center justify-center rounded-full transition-colors duration-150"
  >
    <X class="size-3.5" aria-hidden="true" />
  </button>
</span>

<script>
  document.querySelectorAll<HTMLElement>('[data-filter-chip]').forEach((chip) => {
    const removeButton = chip.querySelector<HTMLButtonElement>('[data-filter-chip-remove]');
    removeButton?.addEventListener('click', () => {
      chip.dispatchEvent(
        new CustomEvent('filterchip:remove', {
          bubbles: true,
          detail: { value: chip.dataset.filterChip },
        }),
      );
    });
  });
</script>
