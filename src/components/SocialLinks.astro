---
/**
 * Official social links, reused in Navbar (mobile menu) and Footer. This is
 * the GENERAL account set (@atp.fcm) — each carrera page links its own
 * Instagram separately (see careers/*.json `instagram` field), since ATP
 * runs one Instagram account per carrera plus this general one.
 *
 * Lucide has no brand marks for Instagram/YouTube/TikTok, so those three
 * are inline SVG paths instead of pulling in an icon library just for
 * brand marks — same "correct the asset, don't add a dependency" approach
 * used for public/branding/logo.svg. Mail is a generic (non-brand) glyph,
 * so it uses Lucide like the rest of the platform's icons.
 */
import Mail from '@lucide/astro/icons/mail';
import InstagramMark from '@/components/icons/InstagramMark.astro';

const links = [
  { platform: 'instagram', label: 'Instagram', href: 'https://www.instagram.com/atp.fcm/' },
  { platform: 'tiktok', label: 'TikTok', href: 'https://www.tiktok.com/@atp.fcm' },
  { platform: 'youtube', label: 'YouTube', href: 'https://www.youtube.com/@atpcienciasmedicas' },
  { platform: 'mail', label: 'Email', href: 'mailto:atpcienciasmedicas@gmail.com' },
] as const;
---

<ul class="flex items-center gap-2">
  {
    links.map(({ platform, label, href }) => (
      <li>
        <a
          href={href}
          class="text-text-secondary ease-standard hover:bg-surface-alt hover:text-text inline-flex size-10 items-center justify-center rounded-full transition-colors duration-150"
          data-platform={platform}
        >
          <span class="sr-only">{label}</span>
          {platform === 'instagram' && <InstagramMark class="size-5" />}
          {platform === 'tiktok' && (
            <svg viewBox="0 0 24 24" fill="currentColor" class="size-5" aria-hidden="true">
              <path d="M16.6 5.82s.51.5 0 0A4.278 4.278 0 0 1 15.54 3h-3.09v12.4a2.592 2.592 0 0 1-2.59 2.5c-1.42 0-2.6-1.16-2.6-2.6 0-1.72 1.66-3.01 3.37-2.48V9.66c-3.45-.46-6.47 2.22-6.47 5.64 0 3.33 2.76 5.7 5.69 5.7 3.14 0 5.69-2.55 5.69-5.7V9.01a7.35 7.35 0 0 0 4.3 1.38V7.3s-1.88.09-3.24-1.48z" />
            </svg>
          )}
          {platform === 'youtube' && (
            <svg viewBox="0 0 24 24" fill="currentColor" class="size-5" aria-hidden="true">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
            </svg>
          )}
          {platform === 'mail' && <Mail class="size-5" aria-hidden="true" />}
        </a>
      </li>
    ))
  }
</ul>
