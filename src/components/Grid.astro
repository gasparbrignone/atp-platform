---
/**
 * Responsive grid for card-like collections (books, activities, tools...).
 * Pure layout, like Container/Section — never add per-item styling here.
 * `cols` sets the desktop column count; smaller breakpoints scale down
 * automatically so callers never need viewport-specific variants.
 */
import type { HTMLAttributes } from 'astro/types';

export type GridCols = 2 | 3 | 4 | 6 | 12;
export type GridGap = 'sm' | 'md' | 'lg';

interface Props extends HTMLAttributes<'div'> {
  as?: keyof HTMLElementTagNameMap;
  cols?: GridCols;
  gap?: GridGap;
}

const { as: Tag = 'div', cols = 3, gap = 'md', class: className, ...rest }: Props = Astro.props;

const colsClasses: Record<GridCols, string> = {
  2: 'grid-cols-1 sm:grid-cols-2',
  3: 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3',
  4: 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-4',
  6: 'grid-cols-2 sm:grid-cols-3 lg:grid-cols-6',
  12: 'grid-cols-4 sm:grid-cols-6 lg:grid-cols-12',
};

const gapClasses: Record<GridGap, string> = {
  sm: 'gap-4',
  md: 'gap-6',
  lg: 'gap-8',
};
---

<Tag class:list={['grid', colsClasses[cols], gapClasses[gap], className]} {...rest}>
  <slot />
</Tag>
