---
/**
 * Full "ATP⚡" wordmark, inlined instead of `<img src="/branding/logo.svg">`.
 * The bolt is always brand pink; the "ATP" text uses `fill="currentColor"`
 * so it tracks whatever text color class the caller sets (e.g. `text-text`)
 * — the same reliable, single-source-of-truth dark mode every other piece
 * of text on the site already uses.
 *
 * The old `<img>` version embedded its own `@media (prefers-color-scheme:
 * dark)` rule *inside* the SVG file — technically valid, but `<img>`-loaded
 * SVGs are a separate rendering context, and that media query is well known
 * to be unreliable there (seen in production: the wordmark stayed blue on a
 * dark background, only fixing itself after a fresh reload). Inlining
 * avoids the whole class of bug instead of patching it.
 */
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'svg'>;

const { class: className, ...rest }: Props = Astro.props;
