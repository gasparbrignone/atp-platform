---
/**
 * The ATP "rayo" mark (same artwork as public/favicon.svg), inlined so it
 * can take `fill="currentColor"` — needed to match the text color of
 * whatever Button variant it sits in (white on primary, blue on
 * outline/ghost...), the same way Lucide icons already behave via
 * `stroke="currentColor"`. The static /favicon.svg has a hardcoded brand
 * pink fill instead, which doesn't adapt.
 */
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'svg'>;

const { class: className, ...rest }: Props = Astro.props;
