---
/**
 * Fase 9 — página institucional "Sumate a ATP". Reemplaza el botón que en
 * Navbar, MobileMenu, Home y las páginas de carrera apuntaba a href="#".
 * Copy institucional real (provista por ATP), contenido inline: es una
 * única página de texto fijo, no una lista de items — mismo criterio que
 * ya aplica el resto del sitio para secciones no data-driven.
 *
 * Las cards de "¿Qué pensamos?" y "¿Por qué sumarte?" usan el slot "image"
 * de Card con un ícono, mismo patrón que las cards de Home/Carreras
 * (src/pages/index.astro) cuando todavía no hay foto real. Cuando existan
 * fotos de ATP, ese `<div slot="image">` se reemplaza por un `<img>` real
 * sin tocar el resto del componente.
 *
 * El formulario es un placeholder de ejemplo (forms.gle/ejemplo-...), igual
 * al patrón ya usado en src/content/activities.ts para registrationUrl.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import Container from '@/components/Container.astro';
import Grid from '@/components/Grid.astro';
import Card from '@/components/Card.astro';
import Button from '@/components/Button.astro';
import Input from '@/components/Input.astro';
import Select from '@/components/Select.astro';
import Textarea from '@/components/Textarea.astro';
import PhotoMarquee from '@/components/PhotoMarquee.astro';
import { careerLabels } from '@/lib/labels';
import facultadRemera from '@/assets/sumate/facultad-remera.jpg';
import standRemera from '@/assets/sumate/stand-remera.jpg';
import acreditacionesRemera from '@/assets/sumate/acreditaciones-remera.jpg';
import escaleraRemera from '@/assets/sumate/escalera-remera.jpg';
import charlaRemera from '@/assets/sumate/charla-remera.jpg';
import bannerRemera from '@/assets/sumate/banner-remera.jpg';
import retratoRemera from '@/assets/sumate/retrato-remera.jpg';
import Landmark from '@lucide/astro/icons/landmark';
import HeartPulse from '@lucide/astro/icons/heart-pulse';
import Users from '@lucide/astro/icons/users';
import BookOpen from '@lucide/astro/icons/book-open';
import Sparkles from '@lucide/astro/icons/sparkles';
import Handshake from '@lucide/astro/icons/handshake';

/**
 * Formspree recibe el POST del formulario nativo de abajo (sin backend
 * propio: ver docs/STACK_DECISIONS.md, sección "Formularios", actualizada
 * al pasar de Google Forms a esto) y reenvía cada respuesta al mail de ATP
 * más un panel web con el historial.
 */
const FORMSPREE_ENDPOINT = 'https://formspree.io/f/xwvdjvyz';

const yearOptions = ['1° año', '2° año', '3° año', '4° año', '5° año', '6° año'];

const galleryPhotos = [
  { image: facultadRemera, alt: 'Integrantes de ATP con la remera oficial frente a la Facultad de Ciencias Médicas.' },
  { image: standRemera, alt: 'Integrantes de ATP en un stand informativo en la calle.' },
  { image: acreditacionesRemera, alt: 'Integrantes de ATP en la mesa de acreditaciones de un encuentro.' },
  { image: escaleraRemera, alt: 'Integrantes de ATP reunidos en la escalinata de la facultad.' },
  { image: charlaRemera, alt: 'Integrante de ATP dando una charla con material didáctico proyectado.' },
  { image: bannerRemera, alt: 'Integrantes de ATP en la escalinata de la facultad bajo el cartel de ATP FCM UNR.' },
  { image: retratoRemera, alt: 'Dos integrantes de ATP con la remera oficial durante una movilización.' },
];

const beliefs = [
  {
    icon: Landmark,
    title: 'Universidad pública',
    description:
      'Creemos en una universidad pública, gratuita y de calidad, comprometida con las necesidades de nuestro pueblo.',
  },
  {
    icon: HeartPulse,
    title: 'La salud como derecho',
    description:
      'Creemos que la salud es un derecho y que formar profesionales también implica pensar el sistema de salud que queremos construir.',
  },
  {
    icon: Users,
    title: 'Comunidad organizada',
    description:
      'La mejor facultad no la hacen los edificios ni los planes de estudio: la hacemos los estudiantes, cuando nos organizamos, compartimos lo que sabemos y construimos comunidad.',
  },
];

const reasons = [
  {
    icon: BookOpen,
    title: 'Para estudiar',
    description:
      'Vas a encontrar compañeros con quienes preparar un parcial o armar un grupo de estudio.',
  },
  {
    icon: Sparkles,
    title: 'Para crecer',
    description:
      'Vas a poder llevar adelante una idea, aprender cosas nuevas y aportar desde el lugar que más te guste.',
  },
  {
    icon: Handshake,
    title: 'Para construir',
    description:
      'Vas a sumarte a proyectos que llegan a miles de estudiantes, junto a gente con la que compartir unos mates después de cursar.',
  },
];
---

<BaseLayout
  title="Sumate a ATP"
  description="ATP es la agrupación estudiantil de la Facultad de Ciencias Médicas (UNR). Conocé quiénes somos, qué pensamos y sumate a construir la facultad que queremos."
  canonicalPath="/sumate"
>
  <Section spacing="lg" reveal={false}>
    <Container class="flex flex-col items-center gap-10">
      <div class="flex max-w-2xl flex-col items-center gap-4 text-center">
        <h1 data-enter class="text-h1 text-text font-extrabold">Sumate a ATP</h1>
        <p data-enter style="--enter-delay: 80ms" class="text-body-lg text-text-secondary">
          Somos estudiantes de la Facultad de Ciencias Médicas que un día decidimos involucrarnos
          un poco más para hacer que la cursada sea mejor para todos. Este formulario es para eso:
          para sumarte a militar en ATP, ayudar a organizar actividades y llevar adelante
          proyectos junto a nosotres — no hace falta haber militado antes ni tener experiencia,
          alcanza con tener ganas de participar.
        </p>
        <Button href="#sumate-cta" size="lg" class="mt-2">
          Completar formulario
        </Button>
      </div>

      <div data-enter style="--enter-delay: 140ms" class="w-full">
        <PhotoMarquee photos={galleryPhotos} />
      </div>
    </Container>
  </Section>

  <Section spacing="md" background="surface-alt">
    <Container class="flex flex-col gap-10">
      <SectionHeader title="¿Qué pensamos?" alignment="center" />
      <Grid cols={3} gap="md">
        {
          beliefs.map(({ icon: Icon, title, description }) => (
            <Card data-reveal>
              <div slot="image" class="p-6 pb-0">
                <div class="bg-secondary/10 text-secondary-strong inline-flex size-12 items-center justify-center rounded-full">
                  <Icon class="size-6" aria-hidden="true" />
                </div>
              </div>
              <h3 slot="title" class="text-h4 text-text font-bold">
                {title}
              </h3>
              <p>{description}</p>
            </Card>
          ))
        }
      </Grid>
    </Container>
  </Section>

  <Section spacing="md">
    <Container class="flex flex-col gap-10">
      <SectionHeader
        title="¿Por qué sumarte?"
        description="Porque ATP es mucho más que una agrupación: es un grupo de compañeros que estudia, organiza actividades, impulsa proyectos y disfruta de la facultad juntos."
        alignment="center"
      />
      <Grid cols={3} gap="md">
        {
          reasons.map(({ icon: Icon, title, description }) => (
            <Card data-reveal>
              <div slot="image" class="p-6 pb-0">
                <div class="bg-secondary/10 text-secondary-strong inline-flex size-12 items-center justify-center rounded-full">
                  <Icon class="size-6" aria-hidden="true" />
                </div>
              </div>
              <h3 slot="title" class="text-h4 text-text font-bold">
                {title}
              </h3>
              <p>{description}</p>
            </Card>
          ))
        }
      </Grid>
    </Container>
  </Section>

  <Section id="sumate-cta" spacing="lg" background="surface-alt">
    <Container class="flex flex-col items-center gap-6 text-center">
      <SectionHeader title="Sumate" alignment="center" />
      <div class="text-body-lg text-text-secondary flex max-w-2xl flex-col gap-4">
        <p>Si te gusta esta forma de vivir la facultad, nos encantaría conocerte.</p>
        <p>
          Completá tus datos y te vamos a escribir para coordinar un encuentro, contarte un poco más
          sobre ATP y responder todas las dudas que tengas. Sin compromiso.
        </p>
        <p>
          Capaz te sumás a organizar un grupo de estudio o una actividad. Capaz hacés nuevos amigos.
          O capaz descubrís un lugar desde donde transformar la facultad.
        </p>
        <p class="text-body-sm text-text-secondary">
          ¿Buscás anotarte a un grupo de estudio o a una actividad puntual, no sumarte a militar en
          ATP? Encontrá la inscripción en la página de esa actividad, en
          <a href="/actividades" class="text-secondary-strong underline underline-offset-2">
            Actividades
          </a>.
        </p>
      </div>

      <form
        data-sumate-form
        action={FORMSPREE_ENDPOINT}
        method="POST"
        novalidate
        class="flex w-full max-w-xl flex-col gap-4 text-left"
      >
        <input type="hidden" name="_subject" value="Nuevo interesado en sumarse a ATP" />

        <div class="flex flex-col gap-2">
          <label for="sumate-name" class="text-caption text-text-secondary font-semibold">
            Nombre y apellido
          </label>
          <Input id="sumate-name" name="name" autocomplete="name" required />
        </div>

        <div class="flex flex-col gap-2">
          <label for="sumate-phone" class="text-caption text-text-secondary font-semibold">
            Teléfono
          </label>
          <Input id="sumate-phone" name="phone" type="tel" autocomplete="tel" required />
        </div>

        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div class="flex flex-col gap-2">
            <label for="sumate-year" class="text-caption text-text-secondary font-semibold">
              Año
            </label>
            <Select id="sumate-year" name="year" required>
              <option value="" selected disabled>
                Elegí un año
              </option>
              {yearOptions.map((year) => <option value={year}>{year}</option>)}
            </Select>
          </div>

          <div class="flex flex-col gap-2">
            <label for="sumate-career" class="text-caption text-text-secondary font-semibold">
              Carrera
            </label>
            <Select id="sumate-career" name="career" required>
              <option value="" selected disabled>
                Elegí tu carrera
              </option>
              {Object.values(careerLabels).map((label) => <option value={label}>{label}</option>)}
            </Select>
          </div>
        </div>

        <div class="flex flex-col gap-2">
          <label for="sumate-message" class="text-caption text-text-secondary font-semibold">
            Contanos lo que quieras (opcional)
          </label>
          <Textarea
            id="sumate-message"
            name="message"
            placeholder="¿Algo que quieras contarnos antes de que te escribamos?"
          />
        </div>

        <Button type="submit" size="lg" data-sumate-submit class="mt-2 self-center" trackId="sumate-formulario">
          Enviar
        </Button>
      </form>

      <p class="text-body-lg text-text font-semibold">Te esperamos. 💙</p>
    </Container>
  </Section>
</BaseLayout>

<script>
  import { showToast } from '@/lib/toast';

  const form = document.querySelector<HTMLFormElement>('[data-sumate-form]');
  const submitButton = form?.querySelector<HTMLButtonElement>('[data-sumate-submit]');

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!submitButton || submitButton.disabled) return;

    if (!form.reportValidity()) return;

    const originalLabel = submitButton.textContent;
    submitButton.disabled = true;
    submitButton.textContent = 'Enviando…';

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (!response.ok) throw new Error('Formspree request failed');

      showToast({
        message: 'Listo, recibimos tus datos. Te vamos a escribir pronto.',
        variant: 'success',
      });
      form.reset();
    } catch {
      showToast({
        message: 'No pudimos enviar el formulario. Probá de nuevo en un rato.',
        variant: 'error',
      });
    } finally {
      submitButton.disabled = false;
      submitButton.textContent = originalLabel;
    }
  });
</script>
