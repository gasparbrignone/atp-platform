---
/**
 * Activity detail. Same dynamic-route pattern as
 * src/pages/carreras/[career].astro: one Astro route + getStaticPaths
 * generates a static page per published activity from the `activities`
 * content collection (src/content.config.ts).
 *
 * Simplified (identity/UX pass): title, date/time/location, full
 * description (falls back to the listing's short summary when a longer
 * one isn't set) and the registration CTA — no status/category shown, same
 * as the listing page. No gallery/speakers/capacity fields from
 * docs/CONTENT_SCHEMA.md are wired in since nothing here needs them.
 */
import type { GetStaticPaths } from 'astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Container from '@/components/Container.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import Button from '@/components/Button.astro';
import ActivityRegistrationForm from '@/components/ActivityRegistrationForm.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { getActivityScheduleLabel } from '@/lib/activitySchedule';
import { uploadThumb } from '@/lib/uploadThumb';

export const getStaticPaths: GetStaticPaths = async () => {
  const activities = await getCollection('activities', ({ data }) => data.published);
  return activities.map((activity) => ({
    params: { slug: activity.id },
    props: { activity },
  }));
};

const { activity } = Astro.props as { activity: CollectionEntry<'activities'> };
const sessions = activity.data.sessions ?? [];
// Una actividad compuesta no tiene un único horario que mostrar como
// description del heading — se lista cada sesión aparte, más abajo.
const meta = sessions.length > 0 ? undefined : getActivityScheduleLabel(activity.data.schedule);
---

<BaseLayout
  title={activity.data.title}
  description={activity.data.description ?? activity.data.summary}
  canonicalPath={`/actividades/${activity.id}`}
>
  <Section spacing="lg">
    <Container class="flex flex-col gap-8">
      <Button href="/actividades" variant="ghost" size="sm" class="self-start">
        ← Volver a actividades
      </Button>

      {
        activity.data.image && (
          <img
            src={uploadThumb(activity.data.image, 'activity')}
            alt=""
            loading="eager"
            width="1200"
            height="675"
            class="aspect-video w-full rounded-md object-cover"
          />
        )
      }

      <SectionHeader as="h1" title={activity.data.title} description={meta} />

      <p class="text-body-lg text-text-secondary max-w-2xl">
        {activity.data.description ?? activity.data.summary}
      </p>

      {
        sessions.length > 0 && (
          <div class="flex flex-col gap-4">
            <h2 class="text-h3 text-text font-bold">Cronograma</h2>
            <ol class="border-border divide-border flex flex-col divide-y rounded-md border">
              {sessions.map((session) => (
                <li class="flex flex-col gap-1 p-4">
                  <span class="text-text font-semibold">{session.title}</span>
                  <span class="text-body-sm text-text-secondary">
                    {getActivityScheduleLabel(session)}
                  </span>
                </li>
              ))}
            </ol>
          </div>
        )
      }

      {
        activity.data.status === 'finalizada' ? (
          <div class="flex flex-wrap gap-3">
            <Button disabled>Inscripción no disponible</Button>
          </div>
        ) : activity.data.registration.useRegistrationForm ? (
          <ActivityRegistrationForm activityId={activity.id} activityTitle={activity.data.title} />
        ) : (
          <div class="flex flex-wrap gap-3">
            {activity.data.registration.registrationUrl ? (
              <Button
                href={activity.data.registration.registrationUrl}
                target="_blank"
                trackId={`inscripcion:${activity.id}`}
              >
                Inscribirse
              </Button>
            ) : (
              <Button disabled>Inscripción no disponible</Button>
            )}
          </div>
        )
      }
    </Container>
  </Section>
</BaseLayout>
