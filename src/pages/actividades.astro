---
/**
 * Actividades. Existing components only, static/local data
 * (src/content/activities.ts), no CMS or backend.
 *
 * Simplified (identity/UX pass): no filters at all — the category filter
 * was removed along with the earlier status filter, so this is now a plain
 * listing. `status` still exists in the data (it disables "Inscribirse"
 * once an activity is `finalizada`) but isn't shown as a public badge —
 * date/time/location/description are the fields a student actually needs.
 *
 * Each card always links to its detail page (src/pages/actividades/[slug].astro)
 * via "Ver más"; "Inscribirse" only renders when `registrationUrl` exists.
 *
 * Split into "Esta semana" / "Próximas actividades" (getActivityTiming, ver
 * src/lib/activitySchedule.ts) en vez de la vieja intro con PhotoGallery +
 * un único listado plano — una actividad `recurring` siempre cae en "Esta
 * semana" (se repite todas las semanas); una puntual se ubica según su
 * `date` contra la semana calendario actual. Las que ya pasaron no se
 * muestran. `featured` sigue existiendo en el schema (lo usa el carrusel de
 * la home, ver src/pages/index.astro) pero esta página ya no lo lee.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Container from '@/components/Container.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import Grid from '@/components/Grid.astro';
import ActivityCard from '@/components/ActivityCard.astro';
import EmptyState from '@/components/EmptyState.astro';
import { getCollection } from 'astro:content';
import { getActivityTiming } from '@/lib/activitySchedule';

const publishedActivities = await getCollection('activities', ({ data }) => data.published);
const thisWeekActivities = publishedActivities.filter(
  (activity) => getActivityTiming(activity.data.schedule ?? {}) === 'this-week',
);
const upcomingActivities = publishedActivities.filter(
  (activity) => getActivityTiming(activity.data.schedule ?? {}) === 'upcoming',
);
---

<BaseLayout
  title="Actividades"
  description="Talleres, cursos y encuentros que armamos en ATP."
  canonicalPath="/actividades"
>
  <Section spacing="lg">
    <Container class="flex flex-col gap-10">
      <SectionHeader as="h1" title="Actividades" />

      {
        thisWeekActivities.length > 0 && (
          <div class="flex flex-col gap-6">
            <SectionHeader title="Esta semana" as="h2" />
            <Grid cols={3} gap="md">
              {thisWeekActivities.map((activity) => (
                <ActivityCard activity={activity} />
              ))}
            </Grid>
          </div>
        )
      }

      {
        upcomingActivities.length > 0 && (
          <div class="flex flex-col gap-6">
            <SectionHeader title="Próximas actividades" as="h2" />
            <Grid cols={3} gap="md">
              {upcomingActivities.map((activity) => (
                <ActivityCard activity={activity} />
              ))}
            </Grid>
          </div>
        )
      }

      {
        thisWeekActivities.length === 0 && upcomingActivities.length === 0 && (
          <EmptyState
            title="Todavía no hay actividades publicadas"
            description="Muy pronto vas a encontrar acá las próximas propuestas de ATP."
          />
        )
      }
    </Container>
  </Section>
</BaseLayout>
