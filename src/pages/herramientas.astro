---
/**
 * +info (listing). Simple catalog — no filters, consistent with the
 * current identity/UX pass (Biblioteca/Actividades dropped their
 * multi-filter setups too).
 *
 * Every card links to its own detail page (src/pages/herramientas/[tool].astro)
 * via "Ver más" — same pattern as Actividades — since an entry can now carry
 * a longer body, photos and extra resource links, not just a name and an
 * external link. "Acceder" (the external `url`) only renders when set.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Container from '@/components/Container.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import Grid from '@/components/Grid.astro';
import Card from '@/components/Card.astro';
import Button from '@/components/Button.astro';
import EmptyState from '@/components/EmptyState.astro';
import BookOpen from '@lucide/astro/icons/book-open';
import Microscope from '@lucide/astro/icons/microscope';
import Calculator from '@lucide/astro/icons/calculator';
import Activity from '@lucide/astro/icons/activity';
import Link from '@lucide/astro/icons/link';
import { getCollection } from 'astro:content';
import type { ToolIconKey } from '@/lib/labels';

const toolIcons: Record<ToolIconKey, typeof BookOpen> = {
  'book-open': BookOpen,
  microscope: Microscope,
  calculator: Calculator,
  activity: Activity,
  link: Link,
};

const publishedTools = await getCollection('tools', ({ data }) => data.published);
---

<BaseLayout
  title="+info"
  description="Atlas, simuladores y accesos útiles para estudiar."
  canonicalPath="/herramientas"
>
  <Section spacing="lg">
    <Container class="flex flex-col gap-10">
      <SectionHeader as="h1" title="+info" />

      {
        publishedTools.length > 0 ? (
          <Grid cols={3} gap="md">
            {publishedTools.map((tool) => {
              const Icon = toolIcons[tool.data.icon];
              return (
                <Card>
                  <div slot="image" class="p-6 pb-0">
                    <div class="bg-secondary/10 text-secondary-strong inline-flex size-12 items-center justify-center rounded-full">
                      <Icon class="size-6" aria-hidden="true" />
                    </div>
                  </div>
                  <h3 slot="title" class="text-h4 text-text font-bold">
                    {tool.data.name}
                  </h3>
                  <p>{tool.data.description}</p>
                  <div slot="actions" class="flex flex-wrap items-center gap-2">
                    <Button href={`/herramientas/${tool.id}`} variant="outline" size="sm">
                      Ver más
                    </Button>
                    {tool.data.url && (
                      <Button
                        href={tool.data.url}
                        target="_blank"
                        size="sm"
                        trackId={`herramienta:${tool.id}`}
                      >
                        Acceder
                      </Button>
                    )}
                  </div>
                </Card>
              );
            })}
          </Grid>
        ) : (
          <EmptyState
            title="Todavía no hay herramientas publicadas"
            description="Muy pronto vas a encontrar acá atlas, simuladores y accesos útiles para estudiar."
          />
        )
      }
    </Container>
  </Section>
</BaseLayout>
