---
/**
 * Biblioteca. Content is local (src/content/books + subjects +
 * resourceTypes), no backend involved — "subjects" and "resourceTypes" are
 * their own CMS-editable collections (not fixed enums) so ATP can add a new
 * materia or tipo de recurso (ej. "Cuaderno del alumno", "Inmunología") from
 * the CMS itself, without a code change.
 *
 * Three filter axes (Carrera, Materia, Tipo) plus a title/author search.
 * Filter chips only ever represent the *currently selected* value of each
 * dropdown — they're not a static legend. Visibility is driven by an inline
 * `style.display`, not a `hidden` class: FilterChip's root element already
 * carries `inline-flex` in its own template, and Tailwind can (depending on
 * build-time utility ordering) generate `.inline-flex{}` *after* `.hidden{}`
 * in the stylesheet, in which case same-specificity `inline-flex` wins the
 * cascade and the chip stays visually shown even with the `hidden` class
 * applied — inline style always wins regardless of that ordering.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Container from '@/components/Container.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import Grid from '@/components/Grid.astro';
import Card from '@/components/Card.astro';
import Badge from '@/components/Badge.astro';
import Button from '@/components/Button.astro';
import Select from '@/components/Select.astro';
import SearchBar from '@/components/SearchBar.astro';
import FilterPanel from '@/components/FilterPanel.astro';
import FilterChip from '@/components/FilterChip.astro';
import EmptyState from '@/components/EmptyState.astro';
import { getCollection } from 'astro:content';
import { careerLabels, type CareerSlug } from '@/lib/labels';
import { uploadThumb } from '@/lib/uploadThumb';

const publishedBooks = await getCollection('books', ({ data }) => data.published);
const careerOptions = Object.entries(careerLabels) as [CareerSlug, string][];

const subjects = await getCollection('subjects');
const resourceTypes = await getCollection('resourceTypes');
const subjectNames = new Map(subjects.map((entry) => [entry.id, entry.data.name]));
const resourceTypeNames = new Map(resourceTypes.map((entry) => [entry.id, entry.data.name]));

function sortedUsedOptions(names: Map<string, string>, usedSlugs: Set<string>) {
  return [...usedSlugs]
    .filter((slug) => names.has(slug))
    .map((slug) => [slug, names.get(slug)!] as const)
    .sort((a, b) => a[1].localeCompare(b[1], 'es'));
}

const usedSubjectSlugs = new Set(publishedBooks.map((book) => book.data.subject));
const usedResourceTypeSlugs = new Set(publishedBooks.map((book) => book.data.resourceType));
const subjectOptions = sortedUsedOptions(subjectNames, usedSubjectSlugs);
const resourceTypeOptions = sortedUsedOptions(resourceTypeNames, usedResourceTypeSlugs);

// Built as one flat array instead of three separate `.map()` blocks in the
// template: Astro only kept the *last* of several sibling expressions each
// targeting the same named slot (`slot="chips"`), silently dropping the
// career/subject chips — merging into a single array + single `.map()`
// sidesteps that entirely.
const filterChips = [
  ...careerOptions.map(([slug, label]) => ({ value: `career:${slug}`, label })),
  ...subjectOptions.map(([slug, label]) => ({ value: `subject:${slug}`, label })),
  ...resourceTypeOptions.map(([slug, label]) => ({ value: `type:${slug}`, label })),
];
---

<BaseLayout
  title="Biblioteca"
  description="Buscá apuntes, libros y guías de todas las materias."
  canonicalPath="/biblioteca"
>
  <Section spacing="lg">
    <Container class="flex flex-col gap-10">
      <SectionHeader as="h1" title="Biblioteca" />

      <FilterPanel title="Buscar">
        <div class="flex min-w-64 flex-1 flex-col gap-1">
          <span class="text-caption text-text-secondary font-semibold" aria-hidden="true">
            Buscar por título o autor
          </span>
          <SearchBar data-library-search label="Buscar por título o autor" />
        </div>

        <div class="flex flex-col gap-1">
          <label for="filter-career" class="text-caption text-text-secondary font-semibold">
            Carrera
          </label>
          <Select id="filter-career" data-filter-career class="min-w-48">
            <option value="all">Todas las carreras</option>
            {careerOptions.map(([slug, label]) => <option value={slug}>{label}</option>)}
          </Select>
        </div>

        <div class="flex flex-col gap-1">
          <label for="filter-subject" class="text-caption text-text-secondary font-semibold">
            Materia
          </label>
          <Select id="filter-subject" data-filter-subject class="min-w-48">
            <option value="all">Todas las materias</option>
            {subjectOptions.map(([slug, label]) => <option value={slug}>{label}</option>)}
          </Select>
        </div>

        <div class="flex flex-col gap-1">
          <label for="filter-type" class="text-caption text-text-secondary font-semibold">
            Tipo
          </label>
          <Select id="filter-type" data-filter-type class="min-w-48">
            <option value="all">Todos los tipos</option>
            {resourceTypeOptions.map(([slug, label]) => <option value={slug}>{label}</option>)}
          </Select>
        </div>

        {
          filterChips.map(({ value, label }) => (
            <FilterChip slot="chips" value={value} label={label} style="display: none" />
          ))
        }
      </FilterPanel>

      <Grid data-library-grid cols={3} gap="md">
        {
          publishedBooks.map((book) => {
            const subjectName = subjectNames.get(book.data.subject) ?? book.data.subject;
            const typeName = resourceTypeNames.get(book.data.resourceType) ?? book.data.resourceType;
            return (
              <Card
                data-reveal
                data-book-card
                data-career={book.data.career.join(' ')}
                data-subject={book.data.subject}
                data-resource-type={book.data.resourceType}
                data-search={`${book.data.author} ${book.data.title} ${subjectName}`}
              >
                <Badge slot="badge" variant="secondary">
                  {typeName}
                </Badge>
                <div slot="title" class="flex items-start gap-3">
                  {book.data.cover && (
                    <img
                      src={uploadThumb(book.data.cover, 'cover')}
                      alt=""
                      loading="lazy"
                      width="40"
                      height="56"
                      class="border-border h-14 w-10 flex-shrink-0 rounded-sm border object-cover"
                    />
                  )}
                  <div class="flex flex-col gap-0.5">
                    <h3 class="text-h4 text-text font-bold">{book.data.title}</h3>
                    <p class="text-body-sm text-text-secondary">{book.data.author}</p>
                  </div>
                </div>
                <p class="text-body-sm text-text-secondary font-semibold">{subjectName}</p>
                <div slot="actions" class="flex items-center justify-between gap-4">
                  <span class="text-caption text-text-secondary">
                    {book.data.career.map((slug) => careerLabels[slug]).join(', ')}
                  </span>
                  {book.data.downloadUrl ? (
                    <Button
                      href={book.data.downloadUrl}
                      target="_blank"
                      variant="outline"
                      size="sm"
                      trackId={`descarga:${book.id}`}
                    >
                      Descargar
                    </Button>
                  ) : (
                    <Badge variant="info">Disponible pronto</Badge>
                  )}
                </div>
              </Card>
            );
          })
        }
      </Grid>

      <EmptyState
        data-library-empty
        class="hidden"
        title="No encontramos nada con esa búsqueda"
        description="Probá con otra palabra o cambiá los filtros."
      />
    </Container>
  </Section>
</BaseLayout>

<script>
  // Fase 12 — Analíticas: qué buscan los estudiantes (GoatCounter, ver
  // BaseLayout.astro). Debounced: un evento por búsqueda "asentada", no uno
  // por tecla — evitar ruido en el panel de analíticas.
  declare global {
    interface Window {
      goatcounter?: { count: (options: { path: string; event?: boolean }) => void };
    }
  }

  const cards = document.querySelectorAll<HTMLElement>('[data-book-card]');
  const chips = document.querySelectorAll<HTMLElement>('[data-filter-chip]');
  const searchInput = document.querySelector<HTMLInputElement>('[data-library-search]');
  const careerSelect = document.querySelector<HTMLSelectElement>('#filter-career');
  const subjectSelect = document.querySelector<HTMLSelectElement>('#filter-subject');
  const typeSelect = document.querySelector<HTMLSelectElement>('#filter-type');
  const grid = document.querySelector<HTMLElement>('[data-library-grid]');
  const emptyState = document.querySelector<HTMLElement>('[data-library-empty]');

  // Búsqueda tolerante a errores de tipeo y tildes: "neter"/"more"/"pro" deben
  // encontrar "Netter"/"Moore"/"Pró". Se normaliza (sin acentos) y se compara
  // por palabra con distancia de edición, no con includes() exacto.
  function normalize(text: string) {
    return text.normalize('NFD').replace(/[̀-ͯ]/g, '').toLowerCase();
  }

  function levenshtein(a: string, b: string) {
    const dp: number[][] = Array.from({ length: a.length + 1 }, (_, i) => [
      i,
      ...Array(b.length).fill(0),
    ]);
    for (let j = 0; j <= b.length; j += 1) dp[0][j] = j;
    for (let i = 1; i <= a.length; i += 1) {
      for (let j = 1; j <= b.length; j += 1) {
        dp[i][j] =
          a[i - 1] === b[j - 1]
            ? dp[i - 1][j - 1]
            : 1 + Math.min(dp[i - 1][j - 1], dp[i - 1][j], dp[i][j - 1]);
      }
    }
    return dp[a.length][b.length];
  }

  function wordMatches(queryWord: string, cardWord: string) {
    if (cardWord.includes(queryWord)) return true;
    const maxDistance = queryWord.length <= 4 ? 1 : 2;
    return levenshtein(queryWord, cardWord) <= maxDistance;
  }

  const cardWords = new Map<HTMLElement, string[]>();
  cards.forEach((card) => {
    cardWords.set(
      card,
      normalize(card.dataset.search ?? '')
        .split(/[^a-z0-9]+/)
        .filter(Boolean),
    );
  });

  function applyFilters() {
    const career = careerSelect?.value ?? 'all';
    const subject = subjectSelect?.value ?? 'all';
    const type = typeSelect?.value ?? 'all';
    const queryWords = normalize(searchInput?.value ?? '')
      .trim()
      .split(/\s+/)
      .filter(Boolean);
    let visibleCount = 0;

    cards.forEach((card) => {
      const cardCareers = (card.dataset.career ?? '').split(' ');
      const matchesCareer = career === 'all' || cardCareers.includes(career);
      const matchesSubject = subject === 'all' || card.dataset.subject === subject;
      const matchesType = type === 'all' || card.dataset.resourceType === type;
      const words = cardWords.get(card) ?? [];
      const matchesQuery =
        queryWords.length === 0 ||
        queryWords.every((queryWord) => words.some((word) => wordMatches(queryWord, word)));
      const matches = matchesCareer && matchesSubject && matchesType && matchesQuery;
      card.classList.toggle('hidden', !matches);
      if (matches) visibleCount += 1;
    });

    chips.forEach((chip) => {
      const value = chip.dataset.filterChip ?? '';
      const isActive =
        (career !== 'all' && value === `career:${career}`) ||
        (subject !== 'all' && value === `subject:${subject}`) ||
        (type !== 'all' && value === `type:${type}`);
      chip.style.display = isActive ? '' : 'none';
    });

    grid?.classList.toggle('hidden', visibleCount === 0);
    emptyState?.classList.toggle('hidden', visibleCount !== 0);
  }

  careerSelect?.addEventListener('change', applyFilters);
  subjectSelect?.addEventListener('change', applyFilters);
  typeSelect?.addEventListener('change', applyFilters);
  searchInput?.addEventListener('input', applyFilters);

  let searchTrackTimeout: ReturnType<typeof setTimeout> | undefined;
  searchInput?.addEventListener('input', () => {
    clearTimeout(searchTrackTimeout);
    searchTrackTimeout = setTimeout(() => {
      const query = searchInput.value.trim().toLowerCase();
      if (query) window.goatcounter?.count({ path: `busqueda:${query}`, event: true });
    }, 600);
  });

  document.addEventListener('filterchip:remove', ((event: CustomEvent<{ value: string }>) => {
    const value = event.detail?.value ?? '';
    if (value.startsWith('career:') && careerSelect) careerSelect.value = 'all';
    if (value.startsWith('subject:') && subjectSelect) subjectSelect.value = 'all';
    if (value.startsWith('type:') && typeSelect) typeSelect.value = 'all';
    applyFilters();
  }) as EventListener);

  document.addEventListener('filterpanel:clear', () => {
    if (careerSelect) careerSelect.value = 'all';
    if (subjectSelect) subjectSelect.value = 'all';
    if (typeSelect) typeSelect.value = 'all';
    if (searchInput) searchInput.value = '';
    applyFilters();
  });

  applyFilters();
</script>
